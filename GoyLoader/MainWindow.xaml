<Window x:Class="GoyLoader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GoyLoader"
        Icon="pack://application:,,,/Resources/AppIcon.ico"
        Width="480" Height="500"
        MinWidth="480" MaxWidth="480"
        MinHeight="500" MaxHeight="500"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{StaticResource BrushImGuiText}"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Border Background="{StaticResource BrushImGuiWindowBg}"
            BorderBrush="{StaticResource BrushImGuiBorder}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.4" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushLoaderTitleBar}"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Image Source="pack://application:,,,/Resources/AppIcon.png" Width="18" Height="18" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="&gt;"
                                   FontFamily="Consolas"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource BrushImGuiAccent}"
                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBlock Text="GoyLoader"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource BrushImGuiTextDim}"
                                   VerticalAlignment="Center"
                                   />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button x:Name="BtnChromeMinimize"
                                Style="{StaticResource LoaderChromeCaptionButton}"
                                Content="&#xE921;" ToolTip="Minimize"
                                Click="OnChromeMinimizeClick"/>
                        <Button x:Name="BtnChromeClose"
                                Style="{StaticResource LoaderChromeCloseButton}"
                                Content="&#xE8BB;" ToolTip="Close"
                                Click="OnChromeCloseClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Accent strip -->
            <Border Grid.Row="1" Height="2" Background="{StaticResource BrushLoaderTopAccent}"/>

            <!-- Body -->
            <Grid Grid.Row="2" Margin="16,12,16,12">
                <Grid x:Name="RootShell">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Subtitle -->
                    <TextBlock x:Name="SubtitleLine" Grid.Row="0"
                               Text="System check &amp; inject"
                               Foreground="{StaticResource BrushImGuiTextMuted}"
                               FontSize="11" Margin="2,0,0,0" Opacity="0">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="SubtitleTrans" Y="6"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>

                    <!-- SYSTEM card -->
                    <Border x:Name="StatusCard" Grid.Row="2"
                            Background="{StaticResource BrushLoaderCard}"
                            CornerRadius="6" BorderThickness="1"
                            BorderBrush="{StaticResource BrushImGuiBorder}"
                            Padding="12,10" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="StatusCardTrans" Y="8"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock Text="SYSTEM" Style="{StaticResource ImGuiSectionTitle}" FontSize="10" Margin="0,0,0,8" />

                            <!-- VC++ -->
                            <Grid Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Grid.Column="0" Width="12" Height="12" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path x:Name="VcIconOk" Data="{StaticResource GeoStatusOk}" Fill="{StaticResource BrushImGuiGreen}" Stretch="Uniform" Visibility="Collapsed"/>
                                        <Path x:Name="VcIconErr" Data="{StaticResource GeoStatusWarn}" Fill="{StaticResource BrushImGuiErr}" Stretch="Uniform" Visibility="Collapsed"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="VC++ Runtime" FontSize="12" Foreground="{StaticResource BrushImGuiText}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="VcDetail" FontSize="11" Foreground="{StaticResource BrushImGuiTextDim}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right"/>
                            </Grid>

                            <Border Style="{StaticResource ImGuiSeparator}" Margin="0,4,0,4"/>

                            <!-- ViGEm -->
                            <Grid Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Grid.Column="0" Width="12" Height="12" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path x:Name="ViGEmIconOk" Data="{StaticResource GeoStatusOk}" Fill="{StaticResource BrushImGuiGreen}" Stretch="Uniform" Visibility="Collapsed"/>
                                        <Path x:Name="ViGEmIconWarn" Data="{StaticResource GeoStatusWarn}" Fill="{StaticResource BrushImGuiWarn}" Stretch="Uniform" Visibility="Collapsed"/>
                                        <Path x:Name="ViGEmIconErr" Data="{StaticResource GeoStatusWarn}" Fill="{StaticResource BrushImGuiErr}" Stretch="Uniform" Visibility="Collapsed"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="ViGEmBus" FontSize="12" Foreground="{StaticResource BrushImGuiText}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="ViGEmDetail" FontSize="11" Foreground="{StaticResource BrushImGuiTextDim}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right"/>
                            </Grid>

                            <Border Style="{StaticResource ImGuiSeparator}" Margin="0,4,0,4"/>

                            <!-- NVIDIA -->
                            <Grid Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Grid.Column="0" Width="12" Height="12" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path x:Name="NvGpuIconOk" Data="{StaticResource GeoStatusOk}" Fill="{StaticResource BrushImGuiGreen}" Stretch="Uniform" Visibility="Collapsed"/>
                                        <Path x:Name="NvGpuIconWarn" Data="{StaticResource GeoStatusWarn}" Fill="{StaticResource BrushImGuiWarn}" Stretch="Uniform" Visibility="Collapsed"/>
                                        <Path x:Name="NvGpuIconErr" Data="{StaticResource GeoStatusWarn}" Fill="{StaticResource BrushImGuiErr}" Stretch="Uniform" Visibility="Collapsed"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="NVIDIA GPU" FontSize="12" Foreground="{StaticResource BrushImGuiText}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="NvidiaGpuDetail" FontSize="11" Foreground="{StaticResource BrushImGuiTextDim}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right"/>
                            </Grid>

                            <Border Style="{StaticResource ImGuiSeparator}" Margin="0,4,0,4"/>

                            <!-- Payload -->
                            <Grid Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Grid.Column="0" Width="12" Height="12" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path x:Name="PayloadIconOk" Data="{StaticResource GeoStatusOk}" Fill="{StaticResource BrushImGuiGreen}" Stretch="Uniform" Visibility="Collapsed"/>
                                        <Path x:Name="PayloadIconWarn" Data="{StaticResource GeoStatusWarn}" Fill="{StaticResource BrushImGuiWarn}" Stretch="Uniform" Visibility="Collapsed"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="Payload" FontSize="12" Foreground="{StaticResource BrushImGuiText}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="PayloadStatus" FontSize="11" Foreground="{StaticResource BrushImGuiTextDim}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Target process card -->
                    <Border x:Name="HostCard" Grid.Row="4"
                            Background="{StaticResource BrushLoaderCard}"
                            CornerRadius="6" BorderThickness="1"
                            BorderBrush="{StaticResource BrushImGuiBorder}"
                            Padding="12,10" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="HostCardTrans" Y="8"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Grid.Column="0" Width="12" Height="12" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path x:Name="HostIconOk" Data="{StaticResource GeoStatusOk}" Fill="{StaticResource BrushImGuiGreen}" Stretch="Uniform" Visibility="Collapsed"/>
                                        <Path x:Name="HostIconIdle" Data="{StaticResource GeoStatusIdle}" Stroke="{StaticResource BrushImGuiTextMuted}" StrokeThickness="1.8" Fill="Transparent" Stretch="Uniform" Visibility="Visible"/>
                                    </Canvas>
                                </Viewbox>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="HostStatusLine" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrushImGuiText}" Text="Host process: checking..."/>
                                    <TextBlock x:Name="SteamHint" Foreground="{StaticResource BrushImGuiTextMuted}" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="BtnLaunchHost" Style="{StaticResource LoaderSecondaryButton}" Content="Launch" FontSize="11" Padding="10,4" Margin="0,0,4,0" Click="OnLaunchHostClick" ToolTip="Launch the installed copy via Steam (if found)"/>
                                    <Button x:Name="BtnRetryDeps" Style="{StaticResource LoaderSecondaryButton}" Content="Retry" FontSize="11" Padding="10,4" Margin="0" Click="OnRetryDepsClick" ToolTip="Re-check and install missing dependencies"/>
                                </StackPanel>
                            </Grid>

                            <Border Style="{StaticResource ImGuiSeparator}" Margin="0,6,0,6"/>

                            <!-- Auto-inject -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Auto-inject" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrushImGuiText}"/>
                                    <TextBlock Text="Inject automatically when the host process is running" FontSize="10" Foreground="{StaticResource BrushImGuiTextMuted}" Margin="0,1,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="AutoInjectToggle" Grid.Column="1"
                                              Style="{StaticResource LoaderToggleSwitch}"
                                              VerticalAlignment="Center"
                                              Checked="OnAutoInjectChanged"
                                              Unchecked="OnAutoInjectChanged"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Version -->
                    <TextBlock Grid.Row="5" Text="v1.0" Foreground="{StaticResource BrushImGuiTextMuted}" FontSize="10" Opacity="0.4" HorizontalAlignment="Right" Margin="0,4,2,0"/>

                    <!-- Footer bar -->
                    <Border x:Name="FooterBar" Grid.Row="7"
                            Background="{StaticResource BrushLoaderFooter}"
                            CornerRadius="5" BorderThickness="1"
                            BorderBrush="{StaticResource BrushImGuiBorder}"
                            Padding="10,8" Opacity="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LogLine" VerticalAlignment="Center"
                                       Foreground="{StaticResource BrushImGuiTextMuted}" FontSize="11"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                            <Button Grid.Column="1" x:Name="BtnInject"
                                    Style="{StaticResource LoaderPrimaryButton}"
                                    Content="INJECT" MinWidth="100"
                                    Click="OnInjectClick"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Setup overlay -->
                <Border x:Name="SetupOverlay" Background="{StaticResource BrushLoaderOverlayScrim}"
                        Visibility="Visible" Panel.ZIndex="100" Opacity="1">
                    <Border x:Name="SetupDialog" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Background="{StaticResource BrushLoaderCard}"
                            BorderBrush="{StaticResource BrushImGuiBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="24,18" MinWidth="320" MaxWidth="380"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="SetupDialogScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock x:Name="SetupTitle" Text="Preparing..." Style="{StaticResource ImGuiSectionTitle}"
                                       FontSize="12" TextAlignment="Center"/>
                            <ProgressBar x:Name="SetupProgress" Margin="0,14,0,8" Minimum="0" Maximum="100" Value="0"
                                         IsIndeterminate="False" Height="4"/>
                            <TextBlock x:Name="SetupDetail" Text="" Foreground="{StaticResource BrushImGuiTextDim}"
                                       FontSize="11" TextWrapping="Wrap" TextAlignment="Center" LineHeight="16"/>
                            <TextBlock x:Name="SetupBytes" Text="" Foreground="{StaticResource BrushImGuiTextMuted}"
                                       FontSize="10" TextAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
