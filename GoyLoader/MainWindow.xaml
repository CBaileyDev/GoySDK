<Window x:Class="GoyLoader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GoyLoader.Controls"
        Title="GoyLoader"
        Icon="pack://application:,,,/Resources/AppIcon.ico"
        Width="880" Height="560"
        MinWidth="880" MaxWidth="880"
        MinHeight="560" MaxHeight="560"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{StaticResource BrushImGuiText}"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <!-- Outer shell: dark window with thin border + ambient drop shadow.
         Layered radial gradients give the muted crimson glow visible in the design. -->
    <Border CornerRadius="12" BorderThickness="0.5" BorderBrush="{StaticResource BrushLoaderTitleBarBorder}">
        <Border.Background>
            <RadialGradientBrush GradientOrigin="0.25,0.15" Center="0.25,0.15" RadiusX="0.85" RadiusY="0.85">
                <GradientStop Color="#1A1213" Offset="0"/>
                <GradientStop Color="{StaticResource PalBgWindow}" Offset="0.55"/>
                <GradientStop Color="{StaticResource PalBg}" Offset="1"/>
            </RadialGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="48" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═════════════════════ Title bar ═════════════════════ -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushLoaderTitleBarGradient}"
                    BorderBrush="{StaticResource BrushLoaderTitleBarBorder}" BorderThickness="0,0,0,0.5"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Brand badge + name -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,8,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{StaticResource PalAccent}" Offset="0"/>
                                    <GradientStop Color="#FFC41E1E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.4" Color="{StaticResource PalAccent}"/>
                            </Border.Effect>
                            <TextBlock Text="G" Foreground="White" FontWeight="Bold" FontSize="9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="GoyLoader"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushImGuiTextDim}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button x:Name="BtnChromeMinimize"
                                Style="{StaticResource LoaderChromeCaptionButton}"
                                Content="&#xE921;" ToolTip="Minimize"
                                Click="OnChromeMinimizeClick"/>
                        <Button x:Name="BtnChromeClose"
                                Style="{StaticResource LoaderChromeCloseButton}"
                                Content="&#xE8BB;" ToolTip="Close"
                                Click="OnChromeCloseClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═════════════════════ Body ═════════════════════ -->
            <Grid Grid.Row="1" Margin="22,20,22,0">
                <Grid x:Name="RootShell">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Header (logo + title + status pill) -->
                        <RowDefinition Height="*"/>      <!-- Two-column body -->
                        <RowDefinition Height="Auto"/>   <!-- Footer -->
                    </Grid.RowDefinitions>

                    <!-- ── Header row ── -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Animated G mark (logo) -->
                        <controls:GoyMark x:Name="HeaderMark"
                                          Width="48" Height="48"
                                          Accent="{StaticResource BrushImGuiAccent}"
                                          Progress="0.4"
                                          Spinning="True" Speed="1"
                                          VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center" Opacity="0">
                            <StackPanel.RenderTransform>
                                <TranslateTransform x:Name="SubtitleTrans" Y="6"/>
                            </StackPanel.RenderTransform>
                            <TextBlock Text="GoyLoader"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushImGuiText}"/>
                            <TextBlock x:Name="SubtitleLine"
                                       Text="V1.0 · ROCKET LEAGUE MOD LOADER"
                                       FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushImGuiTextMuted}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Host status pill -->
                        <Border x:Name="HostStatusPill" Grid.Column="2"
                                CornerRadius="4" Padding="10,5" VerticalAlignment="Center"
                                Background="{StaticResource BrushLoaderPillOkBg}"
                                BorderBrush="{StaticResource BrushLoaderPillOkBorder}" BorderThickness="1"
                                Opacity="0">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="HostStatusPillTrans" Y="-4"/>
                            </Border.RenderTransform>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="HostStatusPillDot" Width="6" Height="6" Margin="0,0,6,0"
                                         Fill="{StaticResource BrushImGuiGreen}" VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="1"
                                                          Color="{StaticResource PalGreen}"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock x:Name="HostStatusPillText"
                                           Text="HOST ONLINE"
                                           FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushImGuiGreen}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── Two-column body ── -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT — Prerequisites card -->
                        <Border x:Name="StatusCard" Grid.Column="0"
                                Background="{StaticResource BrushLoaderCardSubtle}"
                                BorderBrush="{StaticResource BrushLoaderRowDivider}" BorderThickness="1"
                                CornerRadius="8" Opacity="0">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="StatusCardTrans" Y="8"/>
                            </Border.RenderTransform>
                            <StackPanel>
                                <!-- Section header -->
                                <TextBlock Text="PREREQUISITES"
                                           Margin="14,10,14,8"
                                           FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushImGuiTextMuted}"/>

                                <!-- VC++ -->
                                <Border BorderBrush="{StaticResource BrushLoaderRowDivider}" BorderThickness="0,1,0,0">
                                    <Grid Margin="14,11">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid x:Name="VcDot" Width="14" Height="14" VerticalAlignment="Center">
                                            <Ellipse x:Name="VcIconOk" Fill="{StaticResource BrushImGuiGreen}" Visibility="Collapsed"/>
                                            <Path Data="M2.4,7 L5.4,10 L10,4" Stroke="#FF0C0C0E" StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                  Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Visibility="{Binding ElementName=VcIconOk, Path=Visibility}"/>
                                            <Grid x:Name="VcIconErr" Visibility="Collapsed">
                                                <Ellipse Fill="{StaticResource BrushImGuiErr}"/>
                                                <Path Data="M3,3 L11,11 M11,3 L3,11" Stroke="#FF0C0C0E" StrokeThickness="1.5"
                                                      StrokeStartLineCap="Round" Stretch="None"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Visual C++ 2015–2022 x64"
                                                           FontSize="13" FontWeight="Medium"
                                                           Foreground="{StaticResource BrushImGuiText}"/>
                                            </StackPanel>
                                            <TextBlock x:Name="VcDetail" Margin="0,2,0,0"
                                                       FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                       FontSize="11"
                                                       Foreground="{StaticResource BrushImGuiTextDim}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="Checking…"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- ViGEmBus -->
                                <Border BorderBrush="{StaticResource BrushLoaderRowDivider}" BorderThickness="0,1,0,0">
                                    <Grid Margin="14,11">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="14" Height="14" VerticalAlignment="Center">
                                            <Ellipse x:Name="ViGEmIconOk" Fill="{StaticResource BrushImGuiGreen}" Visibility="Collapsed"/>
                                            <Path Data="M2.4,7 L5.4,10 L10,4" Stroke="#FF0C0C0E" StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                  Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Visibility="{Binding ElementName=ViGEmIconOk, Path=Visibility}"/>
                                            <Grid x:Name="ViGEmIconWarn" Visibility="Collapsed">
                                                <Ellipse Fill="{StaticResource BrushImGuiWarn}"/>
                                                <TextBlock Text="!" FontSize="10" FontWeight="ExtraBold"
                                                           Foreground="#FF0C0C0E" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <Grid x:Name="ViGEmIconErr" Visibility="Collapsed">
                                                <Ellipse Fill="{StaticResource BrushImGuiErr}"/>
                                                <Path Data="M3,3 L11,11 M11,3 L3,11" Stroke="#FF0C0C0E" StrokeThickness="1.5"
                                                      Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="ViGEmBus driver" FontSize="13" FontWeight="Medium"
                                                           Foreground="{StaticResource BrushImGuiText}"/>
                                                <Border CornerRadius="3" Padding="5,1" Margin="6,0,0,0" Background="#10FFFFFF">
                                                    <TextBlock Text="OPTIONAL" FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                               FontSize="9" FontWeight="SemiBold"
                                                               Foreground="{StaticResource BrushImGuiTextMuted}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock x:Name="ViGEmDetail" Margin="0,2,0,0"
                                                       FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                       FontSize="11"
                                                       Foreground="{StaticResource BrushImGuiTextDim}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="Checking…"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- NVIDIA GPU -->
                                <Border BorderBrush="{StaticResource BrushLoaderRowDivider}" BorderThickness="0,1,0,0">
                                    <Grid Margin="14,11">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="14" Height="14" VerticalAlignment="Center">
                                            <Ellipse x:Name="NvGpuIconOk" Fill="{StaticResource BrushImGuiGreen}" Visibility="Collapsed"/>
                                            <Path Data="M2.4,7 L5.4,10 L10,4" Stroke="#FF0C0C0E" StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                  Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Visibility="{Binding ElementName=NvGpuIconOk, Path=Visibility}"/>
                                            <Grid x:Name="NvGpuIconWarn" Visibility="Collapsed">
                                                <Ellipse Fill="{StaticResource BrushImGuiWarn}"/>
                                                <TextBlock Text="!" FontSize="10" FontWeight="ExtraBold"
                                                           Foreground="#FF0C0C0E" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <Grid x:Name="NvGpuIconErr" Visibility="Collapsed">
                                                <Ellipse Fill="{StaticResource BrushImGuiErr}"/>
                                                <Path Data="M3,3 L11,11 M11,3 L3,11" Stroke="#FF0C0C0E" StrokeThickness="1.5"
                                                      Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="NVIDIA GPU" FontSize="13" FontWeight="Medium"
                                                           Foreground="{StaticResource BrushImGuiText}"/>
                                                <Border CornerRadius="3" Padding="5,1" Margin="6,0,0,0" Background="#10FFFFFF">
                                                    <TextBlock Text="OPTIONAL" FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                               FontSize="9" FontWeight="SemiBold"
                                                               Foreground="{StaticResource BrushImGuiTextMuted}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock x:Name="NvidiaGpuDetail" Margin="0,2,0,0"
                                                       FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                       FontSize="11"
                                                       Foreground="{StaticResource BrushImGuiTextDim}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="Checking…"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Embedded payload -->
                                <Border BorderBrush="{StaticResource BrushLoaderRowDivider}" BorderThickness="0,1,0,0">
                                    <Grid Margin="14,11">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="14" Height="14" VerticalAlignment="Center">
                                            <Ellipse x:Name="PayloadIconOk" Fill="{StaticResource BrushImGuiGreen}" Visibility="Collapsed"/>
                                            <Path Data="M2.4,7 L5.4,10 L10,4" Stroke="#FF0C0C0E" StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                  Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Visibility="{Binding ElementName=PayloadIconOk, Path=Visibility}"/>
                                            <Grid x:Name="PayloadIconWarn" Visibility="Collapsed">
                                                <Ellipse Fill="{StaticResource BrushImGuiWarn}"/>
                                                <TextBlock Text="!" FontSize="10" FontWeight="ExtraBold"
                                                           Foreground="#FF0C0C0E" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Embedded payload"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource BrushImGuiText}"/>
                                            <TextBlock x:Name="PayloadStatus" Margin="0,2,0,0"
                                                       FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                       FontSize="11"
                                                       Foreground="{StaticResource BrushImGuiTextDim}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="Checking…"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Host process -->
                                <Border BorderBrush="{StaticResource BrushLoaderRowDivider}" BorderThickness="0,1,0,0">
                                    <Grid Margin="14,11">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="14" Height="14" VerticalAlignment="Center">
                                            <Ellipse x:Name="HostIconOk" Fill="{StaticResource BrushImGuiGreen}" Visibility="Collapsed"/>
                                            <Path Data="M2.4,7 L5.4,10 L10,4" Stroke="#FF0C0C0E" StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                  Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Visibility="{Binding ElementName=HostIconOk, Path=Visibility}"/>
                                            <!-- Idle = pending-style hollow ring with rotating cap -->
                                            <Grid x:Name="HostIconIdle" Visibility="Visible">
                                                <Ellipse Stroke="{StaticResource BrushImGuiTextDim}" StrokeThickness="1.5" Fill="Transparent"/>
                                                <Path x:Name="HostIconIdleArc"
                                                      Data="M 7,0.7 A 6.3,6.3 0 0 1 13.3,7"
                                                      Stroke="{StaticResource BrushImGuiText}" StrokeThickness="1.5"
                                                      StrokeStartLineCap="Round"
                                                      RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform x:Name="HostIconIdleRotate" Angle="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Grid>
                                        </Grid>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Host process"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource BrushImGuiText}"/>
                                            <TextBlock x:Name="HostStatusLine" Margin="0,2,0,0"
                                                       FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                       FontSize="11"
                                                       Foreground="{StaticResource BrushImGuiTextDim}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="Waiting for RocketLeague.exe…"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- RIGHT column: target / auto-inject / log -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Target card -->
                            <Border x:Name="HostCard" Grid.Row="0"
                                    Background="{StaticResource BrushLoaderCardSubtle}"
                                    BorderBrush="{StaticResource BrushLoaderRowDivider}" BorderThickness="1"
                                    CornerRadius="8" Padding="14" Opacity="0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="HostCardTrans" Y="8"/>
                                </Border.RenderTransform>
                                <StackPanel>
                                    <TextBlock Text="TARGET"
                                               FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushImGuiTextMuted}"
                                               Margin="0,0,0,8"/>
                                    <TextBlock x:Name="TargetTitle" Text="Rocket League"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource BrushImGuiText}"/>
                                    <TextBlock x:Name="TargetPid" Margin="0,4,0,0"
                                               FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                               FontSize="11"
                                               Foreground="{StaticResource BrushImGuiTextDim}"
                                               Text="Not detected"/>
                                    <TextBlock x:Name="SteamHint" Margin="0,6,0,0"
                                               FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                               FontSize="10"
                                               Foreground="{StaticResource BrushImGuiTextFaint}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>

                            <!-- Auto-inject toggle card -->
                            <Border x:Name="AutoInjectCard" Grid.Row="2"
                                    Background="{StaticResource BrushLoaderCardSubtle}"
                                    BorderBrush="{StaticResource BrushLoaderRowDivider}" BorderThickness="1"
                                    CornerRadius="8" Padding="14,10" Opacity="0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="AutoInjectCardTrans" Y="8"/>
                                </Border.RenderTransform>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="AutoInjectToggle"
                                                  Style="{StaticResource LoaderToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Checked="OnAutoInjectChanged"
                                                  Unchecked="OnAutoInjectChanged"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="Auto-inject"
                                                   FontSize="12" FontWeight="Medium"
                                                   Foreground="{StaticResource BrushImGuiText}"/>
                                        <TextBlock Text="Inject on host detect"
                                                   FontSize="10"
                                                   Foreground="{StaticResource BrushImGuiTextMuted}"
                                                   Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Session log -->
                            <Border x:Name="SessionLogCard" Grid.Row="4"
                                    Background="{StaticResource BrushLoaderLogBg}"
                                    BorderBrush="{StaticResource BrushLoaderRowDivider}" BorderThickness="1"
                                    CornerRadius="8" Padding="12" Opacity="0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="SessionLogTrans" Y="8"/>
                                </Border.RenderTransform>
                                <StackPanel>
                                    <TextBlock Text="SESSION LOG"
                                               FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushImGuiTextFaint}"
                                               Margin="0,0,0,6"/>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="›" Foreground="{StaticResource BrushImGuiTextFaint}"
                                                   FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Grid.Column="1" Text="Loader started."
                                                   FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushImGuiTextDim}"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                    <Grid Margin="0,4,0,0" x:Name="HostLogRow" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="›" Foreground="{StaticResource BrushImGuiTextFaint}"
                                                   FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock x:Name="HostLogLine" Grid.Column="1"
                                                   FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushImGuiTextDim}"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="›" Foreground="{StaticResource BrushImGuiTextFaint}"
                                                   FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock x:Name="LogLine" Grid.Column="1"
                                                   Text="Start the target game, then inject."
                                                   FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushImGuiTextDim}"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ── Footer row ── -->
                    <Border x:Name="FooterBar" Grid.Row="2"
                            BorderBrush="{StaticResource BrushLoaderRowDivider}" BorderThickness="0,1,0,0"
                            Padding="0,14,0,14" Margin="0,16,0,0" Opacity="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnRetryDeps" Grid.Column="0"
                                    Style="{StaticResource LoaderSecondaryButton}"
                                    Click="OnRetryDepsClick"
                                    ToolTip="Re-check and install missing dependencies"
                                    Padding="10,6">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M5.5,1 V4 M5.5,7 V10 M1,5.5 H4 M7,5.5 H10"
                                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stretch="None" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Retry dependency setup" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnLaunchHost" Grid.Column="1"
                                    Style="{StaticResource LoaderSecondaryButton}"
                                    Click="OnLaunchHostClick"
                                    ToolTip="Launch the installed copy via Steam (if found)"
                                    Padding="10,6">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M2,1 L9,5 L2,9 Z"
                                          Fill="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Stretch="None" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Launch host" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock x:Name="FooterSteamPath" Grid.Column="3"
                                       VerticalAlignment="Center" Margin="0,0,10,0"
                                       FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushImGuiTextFaint}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="320"/>

                            <Button Grid.Column="4" x:Name="BtnInject"
                                    Style="{StaticResource LoaderPrimaryButton}"
                                    Click="OnInjectClick" MinWidth="110">
                                <StackPanel Orientation="Horizontal">
                                    <Grid x:Name="InjectIcon" Width="11" Height="11" Margin="0,0,7,0" VerticalAlignment="Center">
                                        <Path Data="M5.5,1 V8 M2.5,5 L5.5,8 L8.5,5 M1.5,10 H9.5"
                                              Stroke="White" StrokeThickness="1.6"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Stretch="None"/>
                                    </Grid>
                                    <Grid x:Name="InjectSpinner" Width="11" Height="11" Margin="0,0,7,0" VerticalAlignment="Center" Visibility="Collapsed">
                                        <Ellipse Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                                        <Path Data="M 5.5,0.6 A 4.9,4.9 0 0 1 10.4,5.5"
                                              Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round"
                                              RenderTransformOrigin="0.5,0.5">
                                            <Path.RenderTransform>
                                                <RotateTransform x:Name="InjectSpinnerRotate" Angle="0"/>
                                            </Path.RenderTransform>
                                        </Path>
                                    </Grid>
                                    <Grid x:Name="InjectCheckIcon" Width="11" Height="11" Margin="0,0,7,0" VerticalAlignment="Center" Visibility="Collapsed">
                                        <Path Data="M2,6 L4.5,8.5 L9,3"
                                              Stroke="White" StrokeThickness="1.8"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Stretch="None"/>
                                    </Grid>
                                    <TextBlock x:Name="BtnInjectLabel" Text="Inject" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═════════════════════ Setup overlay ═════════════════════ -->
                <Border x:Name="SetupOverlay"
                        Visibility="Visible" Panel.ZIndex="100" Opacity="1">
                    <Border.Background>
                        <SolidColorBrush Color="{StaticResource PalBgWindow}" Opacity="0.78"/>
                    </Border.Background>
                    <Border x:Name="SetupDialog"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Width="380" Padding="32,32,32,28"
                            BorderBrush="{StaticResource BrushLoaderTitleBarBorder}" BorderThickness="1"
                            CornerRadius="12"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="{StaticResource PalBgRaised}" Offset="0"/>
                                <GradientStop Color="#FF111113" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="SetupDialogScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <controls:GoyMark x:Name="SetupMark" Width="42" Height="42"
                                                  Accent="{StaticResource BrushImGuiAccent}"
                                                  Progress="0" Spinning="True" Speed="1.5"
                                                  VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="SetupTitle" Text="Preparing your system…"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushImGuiText}"/>
                                    <TextBlock Text="GOYLOADER · SETUP"
                                               FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushImGuiTextFaint}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock x:Name="SetupDetail" Text="Checking prerequisites…"
                                       FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                       FontSize="12" Foreground="{StaticResource BrushImGuiTextDim}"
                                       MinHeight="32" Margin="0,0,0,14" TextWrapping="Wrap"
                                       LineHeight="18"/>

                            <ProgressBar x:Name="SetupProgress"
                                         Minimum="0" Maximum="100" Value="0"
                                         IsIndeterminate="True" Height="3"/>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SetupPercentLabel" Text="WORKING…"
                                           FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushImGuiTextFaint}"/>
                                <TextBlock x:Name="SetupBytes" Grid.Column="1" Text=""
                                           FontFamily="Cascadia Mono, Consolas, ui-monospace"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushImGuiTextFaint}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
